{
  "name": "pi-effect",
  "version": "0.1.0",
  "description": "Effect-native adapter around the public pi coding agent SDK.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./raw": {
      "types": "./dist/raw.d.ts",
      "import": "./dist/raw.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "TODO.md",
    "WRAPPING_RULES.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "validate": "bun run typecheck && bun run test && bun run build && bun run secrets",
    "test": "vitest --run",
    "test:real-agent": "vitest --run --config vitest.real-agent.config.ts",
    "typecheck": "tsc -p tsconfig.test.json",
    "secrets": "bun run secrets:history && bun run secrets:worktree",
    "secrets:history": "gitleaks git . --redact --verbose",
    "secrets:worktree": "gitleaks dir . --redact --verbose",
    "secrets:staged": "gitleaks git . --staged --redact --verbose"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.78.1",
    "effect": "^3.19.6",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
